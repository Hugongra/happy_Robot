# Where the backend lives. Must match where HappyRobot webhooks POST call data.
# Local dev: http://localhost:8000
# Production: https://acme-carrier-api-hugog.fly.dev
VITE_API_BASE_URL=http://localhost:8000
# Must match backend's API_KEY. Browsers see this — for a real deploy, use a per-user session model instead.
VITE_API_KEY=replace-with-strong-random-string

