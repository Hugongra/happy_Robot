# Backend environment variables. Copy to `.env` and fill in.

# --- Security ---
# Any random string; clients must send this in the X-API-Key header.
API_KEY=replace-with-strong-random-string

# --- FMCSA ---
# Get a key at https://mobile.fmcsa.dot.gov/QCDevsite/keyRequest/registerKey
FMCSA_WEB_KEY=

# --- HappyRobot ---
# Used by /api/voice/token to mint LiveKit tokens for browser web-calls.
HAPPYROBOT_API_KEY=
HAPPYROBOT_WORKFLOW_ID=
HAPPYROBOT_BASE_URL=https://platform.happyrobot.ai/api/v2

# --- App ---
DATABASE_URL=sqlite+aiosqlite:///./data/carrier_sales.db
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
